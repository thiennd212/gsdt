{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "GSDT": "Information"
      }
    }
  },
  "Vault": {
    "Enabled": true
  },
  "Gateway": {
    "Mode": "InProcess"
  },
  "Cache": {
    "Mode": "TwoTier"
  }
}
