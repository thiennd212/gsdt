@using Microsoft.AspNetCore.Authentication
@model AqtCoreFW.AuthServer.Controllers.LoginViewModel
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Đăng nhập — AqtCoreFW</title>
    <style>
        body { font-family: system-ui, sans-serif; background: #f5f5f5; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; }
        .card { background: #fff; padding: 2rem; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.1); width: 360px; }
        h1 { font-size: 1.25rem; margin: 0 0 1.5rem; text-align: center; color: #1a1a2e; }
        label { display: block; margin-bottom: .25rem; font-size: .875rem; color: #333; }
        input[type=email], input[type=password] { width: 100%; padding: .5rem; margin-bottom: 1rem; border: 1px solid #d9d9d9; border-radius: 4px; box-sizing: border-box; font-size: .875rem; }
        button { width: 100%; padding: .625rem; background: #1677ff; color: #fff; border: none; border-radius: 4px; font-size: .875rem; cursor: pointer; }
        button:hover { background: #0958d9; }
        .error { color: #ff4d4f; font-size: .8rem; margin-bottom: 1rem; }
        .divider { text-align: center; margin: 1.25rem 0; color: #999; font-size: .8rem; position: relative; }
        .divider::before, .divider::after { content: ""; position: absolute; top: 50%; width: 40%; height: 1px; background: #d9d9d9; }
        .divider::before { left: 0; }
        .divider::after { right: 0; }
        .sso-btn { display: block; width: 100%; padding: .625rem; margin-bottom: .5rem; background: #fff; color: #333; border: 1px solid #d9d9d9; border-radius: 4px; font-size: .875rem; cursor: pointer; text-align: center; text-decoration: none; box-sizing: border-box; }
        .sso-btn:hover { background: #f5f5f5; border-color: #1677ff; color: #1677ff; }
    </style>
</head>
<body>
    <div class="card">
        <h1>AqtCoreFW — Đăng nhập</h1>
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="error">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }
        <form method="post" action="/account/login">
            <input type="hidden" name="ReturnUrl" value="@Model.ReturnUrl" />
            <label for="email">Email</label>
            <input type="email" id="email" name="Email" value="@Model.Email" required autofocus />
            <label for="password">Mật khẩu</label>
            <input type="password" id="password" name="Password" required />
            <button type="submit">Đăng nhập</button>
        </form>
        @{
            var externalSchemes = ViewData["ExternalSchemes"] as IList<AuthenticationScheme> ?? [];
        }
        @if (externalSchemes.Count > 0)
        {
            <div class="divider">hoặc</div>
            @foreach (var scheme in externalSchemes)
            {
                <a href="/account/external-login?provider=@scheme.Name&returnUrl=@Uri.EscapeDataString(Model.ReturnUrl ?? "/")"
                   class="sso-btn">
                    Đăng nhập bằng @(scheme.DisplayName ?? scheme.Name)
                </a>
            }
        }
    </div>
</body>
</html>
