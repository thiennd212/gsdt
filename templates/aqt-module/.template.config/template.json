{
  "$schema": "http://json.schemastore.org/template",
  "author": "AEQUITAS",
  "classifications": ["GSDT", "Module", "DDD"],
  "identity": "GSDT.Module",
  "name": "GSDT Module (4-layer DDD)",
  "shortName": "aqt-module",
  "description": "Scaffolds a new GSDT module with Domain, Application, Infrastructure, and Presentation layers following the golden-path architecture.",
  "tags": {
    "language": "C#",
    "type": "project"
  },
  "sourceName": "ModuleName",
  "preferNameDirectory": true,
  "symbols": {
    "name": {
      "type": "parameter",
      "datatype": "text",
      "description": "The name of the module (PascalCase, e.g., Permits)",
      "replaces": "ModuleName",
      "fileRename": "ModuleName",
      "isRequired": true
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": ["**/bin/**", "**/obj/**"]
        }
      ]
    }
  ]
}
