# Exclude non-build artefacts — keep only src/ relevant to the Docker image

# Version control
.git/
.gitignore

# Documentation and planning
*.md
docs/
plans/

# Tests (not needed in image)
tests/

# Infrastructure definitions (not needed inside the image)
infra/

# Claude / tooling
.claude/

# CI/CD shared library
jenkins-shared-library/

# Build output — prevents Windows NuGet paths (D:\NuGetPackages, C:\Program Files...)
# from breaking Linux container builds (MSB3030/MSB4018)
**/obj/
**/bin/

# IDE / editor
.vs/
.vscode/
**/*.user

# GitHub
.github/

# External repos
external/
worktrees/

# OS artefacts
.DS_Store
Thumbs.db
